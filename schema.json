{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SIF Rule Config",
  "description": "Rule files loaded from Data/SKSE/Plugins/SIF/*.json. Global settings in Data/SKSE/Plugins/SIF.json are configured separately.",
  "type": "object",
  "required": [
    "rules"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/rule"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "rule": {
      "type": "object",
      "required": [
        "icon",
        "match"
      ],
      "properties": {
        "icon": {
          "$ref": "#/$defs/icon"
        },
        "match": {
          "$ref": "#/$defs/match"
        }
      },
      "additionalProperties": false
    },
    "icon": {
      "type": "object",
      "required": [
        "source",
        "label"
      ],
      "properties": {
        "source": {
          "type": "string",
          "description": "SWF path relative to Interface/."
        },
        "label": {
          "type": "string",
          "description": "Export name inside the SWF."
        },
        "fadeMaxDistance": {
          "type": "number",
          "description": "Hard distance cutoff for this icon."
        },
        "fadeStartDistance": {
          "type": "number",
          "description": "Distance at which this icon begins fading."
        },
        "maxInstances": {
          "type": "integer",
          "minimum": 1,
          "maximum": 48,
          "description": "Per-label simultaneous instance limit for this rule."
        }
      },
      "additionalProperties": false
    },
    "formId": {
      "type": "string",
      "pattern": "^.+\\|0x[0-9A-Fa-f]+$"
    },
    "formIdOrArray": {
      "oneOf": [
        {
          "$ref": "#/$defs/formId"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/formId"
          }
        }
      ]
    },
    "rangeObject": {
      "type": "object",
      "properties": {
        "min": {
          "type": "number"
        },
        "max": {
          "type": "number"
        }
      },
      "minProperties": 1,
      "additionalProperties": false
    },
    "magicEffect": {
      "type": "object",
      "description": "Matches when one active effect on the actor satisfies all nested fields.",
      "properties": {
        "formId": {
          "$ref": "#/$defs/formIdOrArray"
        },
        "keywords": {
          "$ref": "#/$defs/formIdOrArray"
        },
        "school": {
          "type": "string"
        },
        "primaryValue": {
          "type": "string"
        },
        "secondaryValue": {
          "type": "string"
        },
        "isHostile": {
          "type": "boolean"
        },
        "isDetrimental": {
          "type": "boolean"
        }
      },
      "patternProperties": {
        "^\\$": {}
      },
      "additionalProperties": false
    },
    "encounterZone": {
      "type": "object",
      "description": "Matches the resolved destination encounter zone for teleport-linked doors.",
      "properties": {
        "formId": {
          "$ref": "#/$defs/formIdOrArray"
        },
        "locationFormId": {
          "$ref": "#/$defs/formIdOrArray"
        },
        "level": {
          "$ref": "#/$defs/rangeObject"
        },
        "deltaPlayerLevel": {
          "oneOf": [
            {
              "type": "number"
            },
            {
              "$ref": "#/$defs/rangeObject"
            }
          ]
        },
        "neverResets": {
          "type": "boolean"
        },
        "matchPCBelowMinimumLevel": {
          "type": "boolean"
        },
        "disableCombatBoundary": {
          "type": "boolean"
        }
      },
      "patternProperties": {
        "^\\$": {}
      },
      "additionalProperties": false
    },
    "match": {
      "type": "object",
      "description": "Top-level fields are AND-combined. Empty match objects are allowed.",
      "properties": {
        "formType": {
          "type": "string",
          "enum": [
            "NPC",
            "Door"
          ]
        },
        "formId": {
          "$ref": "#/$defs/formIdOrArray"
        },
        "baseFormId": {
          "$ref": "#/$defs/formIdOrArray"
        },
        "keywords": {
          "$ref": "#/$defs/formIdOrArray"
        },
        "isQuestAlias": {
          "type": "boolean"
        },
        "worldspaceFormId": {
          "$ref": "#/$defs/formIdOrArray"
        },
        "locationFormId": {
          "$ref": "#/$defs/formIdOrArray"
        },
        "conditionPerk": {
          "$ref": "#/$defs/formId"
        },
        "magicEffect": {
          "$ref": "#/$defs/magicEffect"
        },
        "encounterZone": {
          "$ref": "#/$defs/encounterZone"
        },
        "raceFormId": {
          "$ref": "#/$defs/formIdOrArray"
        },
        "level": {
          "$ref": "#/$defs/rangeObject"
        },
        "isDead": {
          "type": "boolean"
        },
        "isHostile": {
          "type": "boolean"
        },
        "isEssential": {
          "type": "boolean"
        },
        "isProtected": {
          "type": "boolean"
        },
        "isPlayerTeammate": {
          "type": "boolean"
        },
        "isInCombat": {
          "type": "boolean"
        },
        "isWitness": {
          "type": "boolean"
        },
        "not": {
          "oneOf": [
            {
              "$ref": "#/$defs/match"
            },
            {
              "type": "array",
              "items": {
                "$ref": "#/$defs/match"
              }
            }
          ]
        },
        "anyOf": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/match"
          }
        }
      },
      "patternProperties": {
        "^\\$": {}
      },
      "additionalProperties": false
    }
  }
}
